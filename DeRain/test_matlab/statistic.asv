psnr_array = [];
ssim_array = [];

for i=1:12                          % the number of testing samples
   x_true=im2double(imread(strcat('D:\loss_constraint_equi\Data\Unfolding_Methods\node16_result\Derain\R12\R12_RCDNet_loss\results\',sprintf('norain-%d_x2_HR.png',i))));  % groundtruth 
%    x_true=im2double(imread(strcat('/home/jiahongfu/sda5/RCDNet/rcd_result/results/',sprintf('%d_x2_HR.png',i))));
   x_true = rgb2ycbcr(x_true);
   x_true = x_true(:,:,1); 
%    x = im2double(imread(strcat('/home/jiahongfu/4t/works/Equivariant_Proximal_Operator/Response/derain/IDT_test_result_R100L_64patch/',sprintf('norain-%d.png',i))));     %reconstructed image
   x=im2double(imread(strcat('D:\loss_constraint_equi\Data\Unfolding_Methods\node16_result\Derain\R12\R12_RCDNet_loss\results\',sprintf('norain-%d_x2_SR.png',i))));
   %    x = im2double(imread(strcat('/home/jiahongfu/sda5/RCDNet/rcd_result/results/',sprintf('%d_x2_SR.png',i))));
   x = rgb2ycbcr(x);
   x = x(:,:,1);
   tp= tp+ psnr(x,x_true);
   ts= ts+ssim(x*255,x_true*255);
   psnr_array = [psnr_array, psnr(x, x_true)];
   ssim_array = [ssim_array, ssim(x*255,x_true*255)];
   if i==93
       fprintf('num:%f\n',i)
       fprintf('PSNR:%f, ssim:%f \n',psnr(x,x_true), ssim(x*255,x_true*255))
   end
end
